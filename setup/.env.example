POSTGRES_USER=app
POSTGRES_PASSWORD=app_password
POSTGRES_DB=feed_system

REPLICATION_USER=replicator
REPLICATION_PASSWORD=replicator_password

# Read-only role used by the app to query the replica(s)
READER_USER=reader
READER_PASSWORD=reader_password

# Used by `npm run migrate` to reach the master container from the host
DB_HOST=127.0.0.1
DB_PORT=5432
