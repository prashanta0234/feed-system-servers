{
  "name": "setup",
  "version": "1.0.0",
  "type": "module",
  "description": "Infrastructure for the feed system: docker-compose stack + database migrations",
  "scripts": {
    "up": "docker compose up -d",
    "down": "docker compose down",
    "logs": "docker compose logs -f",
    "migrate": "node --env-file=.env --import tsx migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "author": "Prashanta chakraborty",
  "license": "ISC",
  "dependencies": {
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
