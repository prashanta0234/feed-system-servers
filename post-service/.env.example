
# Master database
DB_MASTER_HOST=master-host
DB_MASTER_USER=...  
DB_MASTER_PASSWORD=...
DB_MASTER_NAME=...
DB_MASTER_PORT=5432



# Slave /replica database
DB_REPLICA_1_HOST=replica1-host
DB_REPLICA_1_USER=...  
DB_REPLICA_1_PASSWORD=...
DB_REPLICA_1_NAME=...
DB_REPLICA_1_PORT=5433



# Max connections per pool
DB_POOL_MAX=10


REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0


# HTTP server
PORT=5000


# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=post-images
# Public base url of the bucket (the r2.dev url from the bucket's Public access
# settings, or a custom domain) — NOT the *.r2.cloudflarestorage.com S3 endpoint.
# No trailing slash.
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# Folder (key prefix) inside the bucket that all images live under
R2_KEY_PREFIX=images


# Image upload / processing
IMAGE_MAX_BYTES=10485760      # 10 MB per file
IMAGE_WORKER_CONCURRENCY=4
IMAGE_FULL_WIDTH=1600
IMAGE_THUMB_WIDTH=320
IMAGE_TEMP_TTL=3600           # temp image tracking record lives 1h until claimed

# JWT — verify access tokens issued by the auth service (RS256, public.pem)
JWT_ISSUER=authentication-service
